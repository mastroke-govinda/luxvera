<cart-items id="main-cart-items" data-id="{{ section.id }}" class="cart-items section page-width{% if cart == empty %} is-empty{% endif %}">
  <p id="shopping-cart-line-item-status" class="visually-hidden" role="status"></p>

  {%- if cart == empty -%}
    <div class="cart__empty">
      <h1>{{ 'sections.cart.title' | t }}</h1>
      <p>{{ 'sections.cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="button">{{ 'general.continue_shopping' | t }}</a>
    </div>
  {%- else -%}
    <h1>{{ 'sections.cart.title' | t }}</h1>
    <form action="{{ routes.cart_url }}" method="post" id="cart">
      <div class="js-contents">
        <table class="cart-items__table">
          <thead>
            <tr>
              <th scope="col">{{ 'sections.cart.headings.product' | t }}</th>
              <th scope="col">{{ 'sections.cart.headings.quantity' | t }}</th>
              <th scope="col">{{ 'sections.cart.headings.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr id="CartItem-{{ forloop.index }}" class="cart-item">
                <td class="cart-item__details">
                  <div class="cart-item__media">
                    {%- if item.image -%}
                      <a href="{{ item.url }}">{{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title | escape }}</a>
                    {%- endif -%}
                  </div>
                  <div>
                    <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title | escape }}</a>
                    {%- if settings.show_vendor -%}<p class="cart-item__vendor">{{ item.product.vendor }}</p>{%- endif -%}
                    {%- unless item.product.has_only_default_variant -%}<p class="cart-item__variant">{{ item.variant.title }}</p>{%- endunless -%}
                    <p class="cart-item__price">{{ item.original_price | money }}</p>
                  </div>
                </td>
                <td class="cart-item__quantity">
                  <quantity-input class="quantity">
                    <button class="quantity__button" name="minus" type="button"
                      onclick="this.closest('quantity-input').querySelector('input').stepDown();this.closest('quantity-input').querySelector('input').dispatchEvent(new Event('change',{bubbles:true}))">−</button>
                    <input class="quantity__input" type="number" name="updates[]" value="{{ item.quantity }}" min="0"
                      data-index="{{ forloop.index }}" aria-label="{{ 'products.product.quantity.label' | t }}">
                    <button class="quantity__button" name="plus" type="button"
                      onclick="this.closest('quantity-input').querySelector('input').stepUp();this.closest('quantity-input').querySelector('input').dispatchEvent(new Event('change',{bubbles:true}))">+</button>
                  </quantity-input>
                  <cart-remove-button data-index="{{ forloop.index }}">
                    <a href="{{ item.url_to_remove }}" class="cart-item__remove">{{ 'sections.cart.remove' | t }}</a>
                  </cart-remove-button>
                  <div id="Line-item-error-{{ forloop.index }}" class="cart-item__error" role="alert"><small class="cart-item__error-text"></small></div>
                </td>
                <td class="cart-item__total">
                  {{ item.final_line_price | money }}
                  {% render 'loading-spinner' %}
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    </form>
  {%- endif -%}
</cart-items>
{% schema %}
{
  "name": "Cart items",
  "settings": []
}
{% endschema %}
