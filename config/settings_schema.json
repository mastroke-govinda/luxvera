      {
        "type": "range",
        "id": "spacing_grid_vertical",
        "min": 0,
        "max": 40,
        "step": 2,
        "default": 8,
        "unit": "px",
        "label": "t:settings_schema.layout.settings.spacing_grid_vertical.label"
